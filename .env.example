# Grove credentials - copy to .env and fill in from your Grove request details page.

# The base URL up through (and including) /anthropic. Inspect/Anthropic SDK
# appends /v1/messages on its own.
GROVE_BASE_URL=

# API key from Grove request details page.
GROVE_API_KEY=

# Default model used by the verifier and tasks. Anthropic-native model id
# (not an Azure deployment name) since Grove preserves Anthropic protocol.
GROVE_MODEL=claude-opus-4-6
