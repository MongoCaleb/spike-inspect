# Copy to .env and fill in. .env is gitignored.

# --- Grove (required) ---
# Server-side credentials held by proxy.py; never sent to inspect_ai / inspect_swe.
GROVE_API_KEY=
GROVE_BASE_URL=https://grove.example.internal

# --- Model selection ---
# Used by verify_grove.py (ANTHROPIC_MODEL) and tests/hello.py (OPENAI_MODEL).
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_MODEL=openai/gpt-4o

# --- agent-skills checkout ---
# Path to your local clone of https://github.com/mongodb/agent-skills .
# If unset, tasks/_evals_lib.py falls back to a sibling '../agent-skills' dir.
AGENT_SKILLS_DIR=
